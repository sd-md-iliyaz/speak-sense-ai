# ===========================
# SpeakSense AI  –  .gitignore
# ===========================

# ── Node / npm ──────────────────────────
node_modules/
client/node_modules/
server/node_modules/
ai-service/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Build outputs ────────────────────────
build/
dist/
client/build/
server/dist/
.cache/

# ── Environment / secrets ────────────────
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
server/.env
client/.env
*.pem
*.key
*.secret

# ── Coverage / testing ───────────────────
coverage/
.nyc_output/
*.lcov
jest-results.json

# ── OS files ─────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE ─────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/settings.json
.vscode/launch.json

# ── Python (ai-service) ──────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
venv/
env/
.venv/
ai-service/venv/
*.egg-info/
dist/
*.egg
*.whl
.Python

# ── Docker ───────────────────────────────
docker-compose.override.yml
.docker/

# ── Logs ─────────────────────────────────
logs/
*.log
*.pid
*.seed
*.pid.lock
server/logs/

# ── Runtime data ─────────────────────────
tmp/
temp/
.history/

# ── Misc ─────────────────────────────────
*.tmp
*.bak
*.orig
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
storybook-static/